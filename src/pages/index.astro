---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import heroPhoto from '../assets/photo.jpeg';
import cvFile from '../assets/CV/CV_Jacinta_Chemane.pdf';

const translations = {
  greeting: { en: "Hello, I'm", es: "Hola, soy", pt: "Olá, eu sou" },
  name: { en: "Jacinta Chemane", es: "Jacinta Chemane", pt: "Jacinta Chemane" },
  description: {
    en: "Graduate in Information Technologies, results-oriented and passionate about technology. Ready for challenges and opportunities, transforming academic knowledge into real solutions.",
    es: "Graduada en Tecnologías de la Información, orientada a resultados y apasionada por la tecnología. Lista para desafíos y oportunidades, transformando conocimientos académicos en soluciones reales.",
    pt: "Licenciada em Tecnologias de Informação, orientada para resultados e apaixonada por tecnologia. Pronta para desafios e oportunidades, transformando conhecimentos académicos em soluções reais."
  },
  availability: { en: "Open to work", es: "Disponible para trabajar", pt: "Disponível para trabalhar" },
  viewProjects: { en: "View Projects", es: "Ver Proyectos", pt: "Ver Projetos" },
  getInTouch: { en: "Get in Touch", es: "Contactar", pt: "Contacto" },
  roleTitle: { en: "IT Graduate", es: "Graduada en TI", pt: "Licenciada em TI" },
  downloadCv: { en: "Download CV", es: "Descargar CV", pt: "Baixar CV" },
  about: { en: "About Me", es: "Sobre mí", pt: "Sobre Mim" },
  aboutDesc: {
    en: "I am a graduate in Information Technologies from Universidade Católica de Moçambique, with experience in technical support, IT equipment management, and technical documentation. I work in an organized and detail-oriented way, focusing on efficiency and quality in every task. I adapt well to collaborative teams, follow best practices, and aim to deliver solutions that bring real value. I am interested in opportunities where I can continue growing professionally and contribute to well-structured projects.",
    es: "Soy graduada en Tecnologías de la Información por la Universidad Católica de Mozambique, con experiencia en soporte técnico, gestión de equipos informáticos y documentación técnica. Trabajo de forma organizada y orientada al detalle, con enfoque en la eficiencia y la calidad en cada tarea. Me adapto bien a equipos colaborativos, sigo buenas prácticas y busco entregar soluciones que aporten valor real. Estoy interesada en oportunidades donde pueda seguir creciendo profesionalmente y contribuir a proyectos bien estructurados.",
    pt: "Sou licenciada em Tecnologias de Informação pela Universidade Católica de Moçambique, com experiência em suporte técnico, gestão de equipamentos informáticos e documentação técnica. Trabalho de forma organizada e orientada ao detalhe, com foco na eficiência e qualidade em cada tarefa. Adapto-me bem a equipas colaborativas, sigo boas práticas e procuro entregar soluções que tragam valor real. Estou interessada em oportunidades onde possa continuar a crescer profissionalmente e contribuir para projetos bem estruturados."
  },
  tech: { en: "Skills", es: "Habilidades", pt: "Competências" }
};
---

<Layout title="Home | Jacinta Chemane">
	<Header />
	
	<main class="min-h-screen px-4 sm:px-6 md:px-6">
		<section class="max-w-3xl mx-auto min-h-[calc(100vh-5rem)] flex flex-col justify-center pt-32 sm:pt-48 pb-16 sm:pb-24 fade-in">
			<div class="flex flex-col items-center gap-6 sm:gap-8 text-center">
				<div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">
					<div class="w-24 h-24 sm:w-28 sm:h-28 md:w-32 md:h-32 rounded-full bg-gray-100 dark:bg-gray-800 border-2 border-gray-300 dark:border-gray-600 flex items-center justify-center overflow-hidden animated-border always-visible flex-shrink-0 shadow-lg dark:shadow-white/20">
						<img src={heroPhoto.src} alt="Jacinta Chemane" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
						<span class="text-2xl sm:text-3xl md:text-4xl text-gray-500 dark:text-gray-400 hidden">📷</span>
					</div>
					<div class="animated-border always-visible px-3 sm:px-4 py-2 rounded-full border border-gray-300 dark:border-gray-600 h-fit">
						<p class="text-xs sm:text-sm font-medium text-gray-900 dark:text-white whitespace-nowrap" data-en={translations.availability.en} data-es={translations.availability.es} data-pt={translations.availability.pt}>{translations.availability.pt}</p>
					</div>
				</div>
				<div>
					<p class="text-xs sm:text-sm font-medium text-gray-600 dark:text-gray-400 mb-2" data-en={translations.greeting.en} data-es={translations.greeting.es} data-pt={translations.greeting.pt}>{translations.greeting.pt}</p>
					<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4 sm:mb-6 px-2 sm:px-0" data-en={translations.name.en} data-es={translations.name.es} data-pt={translations.name.pt}>
						{translations.name.pt}
					</h1>
					<p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 max-w-lg mx-auto mb-4 sm:mb-6 px-2 sm:px-0"
						data-en={translations.description.en}
						data-es={translations.description.es}
						data-pt={translations.description.pt}>
						{translations.description.pt}
					</p>
					<!-- CV Download Card -->
					<div class="mt-12 sm:mt-14 flex justify-center px-2 sm:px-0">
						<article class="cv-download-card group" aria-label="Download CV card">
							<div class="cv-download-card-inner">
								<div class="text-gray-50 text-left">
									<span class="cv-initials">Jc</span>
									<p class="cv-role" data-en={translations.roleTitle.en} data-es={translations.roleTitle.es} data-pt={translations.roleTitle.pt}>{translations.roleTitle.pt}</p>
								</div>
								<a href={cvFile} download="CV_Jacinta_Chemane.pdf" class="cv-download-button" data-en={translations.downloadCv.en} data-es={translations.downloadCv.es} data-pt={translations.downloadCv.pt}>
									<span>{translations.downloadCv.pt}</span>
									<svg class="w-5 h-5 fill-current" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
										<path d="M22.1,77.9a4,4,0,0,1,4-4H73.9a4,4,0,0,1,0,8H26.1A4,4,0,0,1,22.1,77.9ZM35.2,47.2a4,4,0,0,1,5.7,0L46,52.3V22.1a4,4,0,1,1,8,0V52.3l5.1-5.1a4,4,0,0,1,5.7,0,4,4,0,0,1,0,5.6l-12,12a3.9,3.9,0,0,1-5.6,0l-12-12A4,4,0,0,1,35.2,47.2Z" fill-rule="evenodd"></path>
									</svg>
								</a>
							</div>
							<svg class="cv-avatar cv-avatar-main" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" aria-hidden="true"><path d="M50.4 51C40.5 49.1 40 46 40 44v-1.2a18.9 18.9 0 0 0 5.7-8.8h.1c3 0 3.8-6.3 3.8-7.3s.1-4.7-3-4.7C53 4 30 0 22.3 6c-5.4 0-5.9 8-3.9 16-3.1 0-3 3.8-3 4.7s.7 7.3 3.8 7.3c1 3.6 2.3 6.9 4.7 9v1.2c0 2 .5 5-9.5 6.8S2 62 2 62h60a14.6 14.6 0 0 0-11.6-11z"/></svg>
							<svg class="cv-avatar cv-avatar-accent" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" aria-hidden="true"><path d="M50.4 51C40.5 49.1 40 46 40 44v-1.2a18.9 18.9 0 0 0 5.7-8.8h.1c3 0 3.8-6.3 3.8-7.3s.1-4.7-3-4.7C53 4 30 0 22.3 6c-5.4 0-5.9 8-3.9 16-3.1 0-3 3.8-3 4.7s.7 7.3 3.8 7.3c1 3.6 2.3 6.9 4.7 9v1.2c0 2 .5 5-9.5 6.8S2 62 2 62h60a14.6 14.6 0 0 0-11.6-11z"/></svg>
						</article>
					</div>

					
					<div class="mt-14 flex flex-wrap gap-2 sm:gap-3 justify-center px-2 sm:px-0">
						<a href="/projects" class="cursor-pointer px-4 sm:px-5 py-2 sm:py-2.5 text-sm sm:text-base bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-medium rounded-full hover:animated-bg transition-all" data-en={translations.viewProjects.en} data-es={translations.viewProjects.es} data-pt={translations.viewProjects.pt}>
							{translations.viewProjects.pt}
						</a>
						<a href="/contact" class="animated-border cursor-pointer px-4 sm:px-5 py-2 sm:py-2.5 text-sm sm:text-base border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white font-medium rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" data-en={translations.getInTouch.en} data-es={translations.getInTouch.es} data-pt={translations.getInTouch.pt}>
							{translations.getInTouch.pt}
						</a>
					</div>
				</div>
			</div>
		</section>

		<section class="max-w-3xl mx-auto py-12 sm:py-16 border-t border-gray-200 dark:border-gray-700 parallax-section fade-in px-2 sm:px-0">
			<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-6 sm:mb-8" data-en={translations.about.en} data-es={translations.about.es} data-pt={translations.about.pt}>{translations.about.pt}</h2>
			<div class="space-y-3 sm:space-y-4 text-base sm:text-lg leading-relaxed text-gray-600 dark:text-gray-400" data-en={translations.aboutDesc.en} data-es={translations.aboutDesc.es} data-pt={translations.aboutDesc.pt}>
				{translations.aboutDesc.pt}
			</div>
		</section>

		<section class="max-w-3xl mx-auto py-12 sm:py-16 border-t border-gray-200 dark:border-gray-700 parallax-section fade-in px-2 sm:px-0">
			<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-6 sm:mb-8" data-en={translations.tech.en} data-es={translations.tech.es} data-pt={translations.tech.pt}>{translations.tech.pt}</h2>
			
			<div class="tech-ticker-container">
				<div class="tech-ticker-content">
					{['Java', 'JavaScript', 'TypeScript', 'React', 'Astro', 'Tailwind CSS', 'Node.js', 'PostgreSQL', 'MongoDB', 'MySQL', 'Git',
					  'Java', 'JavaScript', 'TypeScript', 'React', 'Astro', 'Tailwind CSS', 'Node.js', 'PostgreSQL', 'MongoDB', 'MySQL', 'Git'].map(skill => (
						<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
							<p class="text-sm font-medium text-gray-900 dark:text-white">{skill}</p>
						</div>
					))}
				</div>
			</div>
		</section>
	</main>

	<Footer />

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) entry.target.classList.add('visible');
				});
			}, { threshold: 0.1 });

			document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

			window.addEventListener('scroll', () => {
				const scrolled = window.pageYOffset;
				document.querySelectorAll('.parallax-section').forEach(section => {
					(section as HTMLElement).style.transform = `translateY(${scrolled * 0.1}px)`;
				});
			});
		});
	</script>
</Layout>